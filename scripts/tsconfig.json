{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "../node_modules/.temp/scripts.tsbuildinfo",
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": true,
    "types": ["node", "greasemonkey"],
    "alwaysStrict": false,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["./**/*.ts", "../src/**/*.ts"]
}
