{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "../node_modules/.temp/src.tsbuildinfo",
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "types": ["greasemonkey"],
    "alwaysStrict": false,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["./**/*.ts"]
}
